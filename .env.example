# ============================================================
# DSAverse Environment Variable Template
# Copy this file to a new file named '.env' in this directory
# and configure your keys to unlock all system functionalities.
# ============================================================

# Application Secrets
JWT_SECRET=YOUR_JWT_SECRET

# Google Gemini Pro / Flash API Key
# Obtain your key from the Google AI Studio console: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Database & Message Queue (Local defaults)
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
RABBITMQ_PASSWORD=YOUR_RABBITMQ_PASSWORD

# Database Connection (Production/Deployment)
DB_HOST=YOUR_DATABASE_HOST
DB_PORT=5432
DB_NAME=YOUR_DATABASE_NAME
DB_USERNAME=YOUR_DATABASE_USERNAME
DB_PASSWORD=YOUR_DATABASE_PASSWORD
DB_SSLMODE=require

# Full Spring Datasource overrides
SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR_DATABASE_HOST:5432/YOUR_DATABASE_NAME?sslmode=require
SPRING_DATASOURCE_USERNAME=YOUR_DATABASE_USERNAME
SPRING_DATASOURCE_PASSWORD=YOUR_DATABASE_PASSWORD

# Upstash Redis Configuration (Production/Deployment)
REDIS_HOST=YOUR_REDIS_HOST
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_SSL_ENABLED=true
