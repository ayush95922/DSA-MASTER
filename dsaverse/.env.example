# ============================================================
# DSAverse Environment Variable Template
# Copy this file to a new file named '.env' in this directory
# and configure your keys to unlock all system functionalities.
# ============================================================

# Application Secrets
JWT_SECRET=YOUR_JWT_SECRET

# Google Gemini Pro / Flash API Key
# Obtain your key from the Google AI Studio console: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Database & Message Queue
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
RABBITMQ_PASSWORD=YOUR_RABBITMQ_PASSWORD
